{
  "name": "teste-3-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo configuration",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:up": "cd packages/database && docker-compose up -d",
    "db:down": "cd packages/database && docker-compose down",
    "backend:install": "cd packages/backend && python3 -m venv venv && ./venv/bin/pip install -r requirements.txt",
    "backend:dev": "cd packages/backend && ./venv/bin/flask --app main run --debug",
    "build": "cd packages/frontend && npm install && npm run build",
    "dev": "cd packages/frontend && npm run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
